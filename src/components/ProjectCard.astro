---
interface Props {
  title: string;
  category: string;
  imageUrl: string;
  link: string;
}

const { title, category, imageUrl, link } = Astro.props;
---

<a href={link} class="group block w-full">
    <div class="w-full aspect-[4/3] bg-neutral-100 rounded-3xl overflow-hidden mb-6 relative">
        <div class="absolute inset-0 bg-neutral-900/5 group-hover:bg-transparent transition-colors duration-500 z-10"></div>
        {imageUrl && imageUrl !== "/placeholder-1.jpg" && imageUrl !== "/placeholder-2.jpg" ? (
            <img src={imageUrl} alt={title} class="w-full h-full object-cover scale-100 group-hover:scale-105 transition-transform duration-700 ease-out" />
        ) : (
            <div class="w-full h-full flex flex-col items-center justify-center text-neutral-400 bg-neutral-50 border border-neutral-200/50">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="mb-2 opacity-50">
                    <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                    <circle cx="8.5" cy="8.5" r="1.5"></circle>
                    <polyline points="21 15 16 10 5 21"></polyline>
                </svg>
                <span class="text-xs uppercase tracking-widest font-medium opacity-50">Image Placeholder</span>
            </div>
        )}
    </div>
    
    <div class="flex items-start justify-between">
        <div>
            <h3 class="text-xl font-semibold text-neutral-900 tracking-tight">{title}</h3>
            <p class="text-neutral-500 text-sm mt-1.5">{category}</p>
        </div>
        <div class="w-10 h-10 mt-1 rounded-full border border-neutral-200 flex items-center justify-center group-hover:border-neutral-900 group-hover:bg-neutral-900 group-hover:text-white transition-all duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="7" y1="17" x2="17" y2="7"></line>
                <polyline points="7 7 17 7 17 17"></polyline>
            </svg>
        </div>
    </div>
</a>
