---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getLangFromUrl } from '../i18n/ui';

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "Asu Pınar Aksu | Product Designer",
  description = "Research-driven Product Designer specializing in user research, data analysis, and insight generation to create user-centered, meaningful digital products."
} = Astro.props;

const lang = getLangFromUrl(Astro.url);
const canonicalURL = new URL(Astro.url.pathname, 'https://asu-aksu.com');

// Build hreflang alternate URLs
const currentPath = Astro.url.pathname;
const pathWithoutLang = lang === 'en' ? currentPath : currentPath.replace(/^\/tr/, '') || '/';
const enUrl = new URL(pathWithoutLang, 'https://asu-aksu.com').href;
const trUrl = new URL(`/tr${pathWithoutLang === '/' ? '' : pathWithoutLang}`, 'https://asu-aksu.com').href;
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="canonical" href={canonicalURL.href} />
		<link rel="alternate" hreflang="en" href={enUrl} />
		<link rel="alternate" hreflang="tr" href={trUrl} />
		<link rel="alternate" hreflang="x-default" href={enUrl} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<!-- Open Graph / Social -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL.href} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:locale" content={lang === 'en' ? 'en_US' : 'tr_TR'} />
		<meta property="og:site_name" content="Asu Pınar Aksu" />
		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
	</head>
	<body class="min-h-screen flex flex-col items-center">
		<!-- Layout Wrapper: Constraints the max width for extreme spaciousness and readability -->
		<div class="w-full max-w-6xl px-6 md:px-12 lg:px-24 mx-auto flex flex-col flex-grow">
			<Header />
			<main class="flex-grow w-full py-16 md:py-24">
				<slot />
			</main>
			<Footer />
		</div>
	</body>
</html>
