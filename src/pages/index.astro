---
import Layout from '../layouts/Layout.astro';
import ServiceCard from '../components/ServiceCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { siteMetadata, services, featuredWorks } from '../data/data';
---

<Layout title={siteMetadata.title} description={siteMetadata.description}>
    <!-- Hero Section -->
    <section class="pt-24 pb-32 md:pt-32 md:pb-40">
        <p class="text-sm font-medium text-neutral-400 uppercase tracking-widest mb-6">Product & Service Designer</p>
        <h1 class="text-5xl md:text-7xl lg:text-8xl font-bold tracking-tighter text-neutral-900 leading-[1.1] mb-8">
            Designing <span class="text-neutral-400">minimal,</span> <br class="hidden md:block" />
            intuitive &amp; premium <br class="hidden md:block" />
            digital experiences.
        </h1>
        <p class="text-lg md:text-xl text-neutral-500 max-w-2xl leading-relaxed mb-12">
            I specialize in uncovering user needs and translating them into pixel-perfect, scalable design systems and service experiences.
        </p>
        <div class="flex items-center space-x-4">
            <a href="/work" class="px-8 py-4 bg-neutral-900 text-white font-medium rounded-full hover:bg-neutral-800 transition-all duration-300">
                View My Work
            </a>
            <a href="/contact" class="px-8 py-4 bg-white text-neutral-900 font-medium rounded-full border border-neutral-200 hover:border-neutral-900 transition-all duration-300">
                Contact Me
            </a>
        </div>
    </section>

    <!-- Services Preview -->
    <section class="py-24 border-t border-neutral-100">
        <div class="flex items-end justify-between mb-16">
            <div>
                <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-neutral-900 mb-4">What I Do</h2>
                <p class="text-neutral-500 max-w-xl text-lg">A holistic approach to product and service design.</p>
            </div>
            <a href="/services" class="hidden md:flex items-center space-x-2 text-sm font-medium text-neutral-500 hover:text-neutral-900 transition-colors">
                <span>All Services</span>
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="5" y1="12" x2="19" y2="12"></line>
                    <polyline points="12 5 19 12 12 19"></polyline>
                </svg>
            </a>
        </div>
        
        <!-- Show only service titles as a clean list -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {services.map(service => (
                <ServiceCard title={service.title} description={service.description} />
            ))}
        </div>

        <a href="/services" class="mt-10 md:hidden flex items-center space-x-2 text-sm font-medium text-neutral-500 hover:text-neutral-900 transition-colors">
            <span>View All Services</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
        </a>
    </section>

    <!-- Work Preview -->
    <section class="py-24 border-t border-neutral-100">
        <div class="flex items-end justify-between mb-16">
            <div>
                <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-neutral-900 mb-4">Selected Work</h2>
                <p class="text-neutral-500 max-w-xl text-lg">Recent projects emphasizing minimalism and usability.</p>
            </div>
            <a href="/work" class="hidden md:flex items-center space-x-2 text-sm font-medium text-neutral-500 hover:text-neutral-900 transition-colors">
                <span>All Projects</span>
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="5" y1="12" x2="19" y2="12"></line>
                    <polyline points="12 5 19 12 12 19"></polyline>
                </svg>
            </a>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-16">
            {featuredWorks.map(project => (
                <ProjectCard 
                    title={project.title} 
                    category={project.category} 
                    imageUrl={project.imageUrl} 
                    link={project.link} 
                />
            ))}
        </div>

        <a href="/work" class="mt-10 md:hidden flex items-center space-x-2 text-sm font-medium text-neutral-500 hover:text-neutral-900 transition-colors">
            <span>View All Projects</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
        </a>
    </section>

    <!-- CTA Banner -->
    <section class="py-24 border-t border-neutral-100">
        <div class="text-center max-w-2xl mx-auto">
            <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-neutral-900 leading-[1.1] mb-6">
                Let's build something<br />exceptional together.
            </h2>
            <p class="text-neutral-500 text-lg mb-10">
                Whether you need a design system from scratch or want to optimize your user experience, I'm here to help.
            </p>
            <a href="/contact" class="inline-flex px-8 py-4 bg-neutral-900 text-white font-medium rounded-full hover:bg-neutral-800 transition-all duration-300">
                Start a Conversation
            </a>
        </div>
    </section>
</Layout>
