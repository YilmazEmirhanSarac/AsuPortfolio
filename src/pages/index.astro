---
import Layout from '../layouts/Layout.astro';
import ServiceCard from '../components/ServiceCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { siteMetadata, services, featuredWorks } from '../data/data';
---

<Layout title={siteMetadata.title} description={siteMetadata.description}>
    <!-- Hero Section -->
    <section class="pt-24 pb-32 md:pt-32 md:pb-40">
        <h1 class="text-5xl md:text-7xl lg:text-8xl font-bold tracking-tighter text-neutral-900 leading-[1.1] mb-8">
            Designing <span class="text-neutral-400">minimal,</span> <br class="hidden md:block" />
            intuitive &amp; premium <br class="hidden md:block" />
            digital experiences.
        </h1>
        <p class="text-lg md:text-xl text-neutral-500 max-w-2xl leading-relaxed mb-12">
            Hi, I'm <strong class="text-neutral-900 font-medium">{siteMetadata.author}</strong>. I specialize in uncovering user needs and translating them into pixel-perfect, scalable design systems.
        </p>
        <div class="flex items-center space-x-4">
            <a href="#work" class="px-8 py-4 bg-neutral-900 text-white font-medium rounded-full hover:bg-neutral-800 transition-all duration-300">
                View My Work
            </a>
            <a href="#contact" class="px-8 py-4 bg-white text-neutral-900 font-medium rounded-full border border-neutral-200 hover:border-neutral-900 transition-all duration-300">
                Contact Me
            </a>
        </div>
    </section>

    <!-- Services Section -->
    <section id="services" class="py-24 border-t border-neutral-100">
        <div class="mb-16">
            <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-neutral-900 mb-4">Core Services</h2>
            <p class="text-neutral-500 max-w-xl text-lg">A holistic approach to product design, from initial discovery to final pixel-perfect execution.</p>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {services.map(service => (
                <ServiceCard title={service.title} description={service.description} />
            ))}
        </div>
    </section>

    <!-- Featured Work Section -->
    <section id="work" class="py-24 border-t border-neutral-100">
        <div class="mb-16">
            <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-neutral-900 mb-4">Selected Work</h2>
            <p class="text-neutral-500 max-w-xl text-lg">A curated collection of my recent design projects emphasizing minimalism and usability.</p>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-16">
            {featuredWorks.map(project => (
                <ProjectCard 
                    title={project.title} 
                    category={project.category} 
                    imageUrl={project.imageUrl} 
                    link={project.link} 
                />
            ))}
        </div>
    </section>
</Layout>
