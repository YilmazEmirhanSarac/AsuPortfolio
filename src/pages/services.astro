---
import Layout from '../layouts/Layout.astro';
import ServiceCard from '../components/ServiceCard.astro';
import { services } from '../data/data';
---

<Layout title="Services | Asu Pınar Aksu" description="Product Discovery, UI Design, UX Optimization, and Mentorship services offered by Asu Pınar Aksu.">
    <section class="py-12 md:py-20">
        <p class="text-sm font-medium text-neutral-400 uppercase tracking-widest mb-4">What I Offer</p>
        <h1 class="text-4xl md:text-6xl font-bold tracking-tight text-neutral-900 leading-[1.1] mb-6">Services</h1>
        <p class="text-lg text-neutral-500 max-w-2xl leading-relaxed mb-20">
            I partner with startups, agencies, and product teams to deliver design work that is research-driven, user-centered, and built to scale.
        </p>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {services.map(service => (
                <ServiceCard title={service.title} description={service.description} />
            ))}
        </div>

        <!-- CTA -->
        <div class="mt-24 pt-16 border-t border-neutral-100 text-center">
            <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-neutral-900 mb-4">Interested in working together?</h2>
            <p class="text-neutral-500 mb-8 max-w-md mx-auto">Let's discuss how I can help bring your vision to life.</p>
            <a href="/contact" class="inline-flex px-8 py-4 bg-neutral-900 text-white font-medium rounded-full hover:bg-neutral-800 transition-all duration-300">
                Get in Touch
            </a>
        </div>
    </section>
</Layout>
