---
import Layout from '../layouts/Layout.astro';
import ContactForm from '../components/ContactForm.tsx';
import { siteMetadata } from '../data/en';
---

<Layout title="Contact | Asu Pınar Aksu" description="Get in touch with Asu Pınar Aksu for design inquiries, collaborations, or mentorship.">
    <section class="py-12 md:py-20">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24">
            <div>
                <p class="text-sm font-medium text-neutral-400 uppercase tracking-widest mb-4">Get in Touch</p>
                <h1 class="text-4xl md:text-5xl font-bold tracking-tight text-neutral-900 leading-[1.1] mb-6">
                    Let's build something<br class="hidden lg:block" /> exceptional.
                </h1>
                <p class="text-neutral-500 text-lg mb-12 max-w-md">
                    Whether you're looking to revamp a complex dashboard, build a minimalist design system from scratch, or need mentorship — I'm here to help.
                </p>
                
                <div class="space-y-8">
                    <div>
                        <p class="text-sm font-medium text-neutral-400 uppercase tracking-widest mb-2">Email</p>
                        <a href={`mailto:${siteMetadata.email}`} class="text-neutral-900 font-medium hover:text-neutral-500 transition-colors underline underline-offset-4">
                            {siteMetadata.email}
                        </a>
                    </div>
                    <div>
                        <p class="text-sm font-medium text-neutral-400 uppercase tracking-widest mb-2">LinkedIn</p>
                        <a href="https://www.linkedin.com/in/asupinaraksu/" target="_blank" rel="noopener noreferrer" class="text-neutral-900 font-medium hover:text-neutral-500 transition-colors underline underline-offset-4">
                            linkedin.com/in/asupinaraksu
                        </a>
                    </div>
                </div>
            </div>
            <div>
                <ContactForm client:load serviceIdentifier="General Inquiry" />
            </div>
        </div>
    </section>
</Layout>
