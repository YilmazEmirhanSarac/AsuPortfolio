---
import Layout from '../../layouts/Layout.astro';
import ContactForm from '../../components/ContactForm.tsx';
import { siteMetadata } from '../../data/tr';
---

<Layout title="İletişim | Asu Pınar Aksu" description="Tasarım projeleri, iş birlikleri veya mentorluk için Asu Pınar Aksu ile iletişime geçin.">
    <section class="py-12 md:py-20">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24">
            <div>
                <p class="text-sm font-medium text-neutral-400 uppercase tracking-widest mb-4">İletişime Geçin</p>
                <h1 class="text-4xl md:text-5xl font-bold tracking-tight text-neutral-900 leading-[1.1] mb-6">
                    Birlikte harika bir şeyler<br class="hidden lg:block" /> inşa edelim.
                </h1>
                <p class="text-neutral-500 text-lg mb-12 max-w-md">
                    Karmaşık bir kontrol panelini yenilemek, sıfırdan minimalist bir tasarım sistemi oluşturmak ya da mentorluk almak istiyorsanız — yardımcı olmak için buradayım.
                </p>
                
                <div class="space-y-8">
                    <div>
                        <p class="text-sm font-medium text-neutral-400 uppercase tracking-widest mb-2">E-posta</p>
                        <a href={`mailto:${siteMetadata.email}`} class="text-neutral-900 font-medium hover:text-neutral-500 transition-colors underline underline-offset-4">
                            {siteMetadata.email}
                        </a>
                    </div>
                    <div>
                        <p class="text-sm font-medium text-neutral-400 uppercase tracking-widest mb-2">LinkedIn</p>
                        <a href="https://www.linkedin.com/in/asupinaraksu/" target="_blank" rel="noopener noreferrer" class="text-neutral-900 font-medium hover:text-neutral-500 transition-colors underline underline-offset-4">
                            linkedin.com/in/asupinaraksu
                        </a>
                    </div>
                </div>
            </div>
            <div>
                <ContactForm 
                    client:load 
                    serviceIdentifier="Genel Sorgu"
                    t={{
                        nameLabel: "İsminiz",
                        namePlaceholder: "Ayşe Yılmaz",
                        emailLabel: "E-posta Adresi",
                        emailPlaceholder: "ayse@ornek.com",
                        messageLabel: "Proje Detayları",
                        messagePlaceholder: "Hedeflerinizden, zaman çizelgenizden ve ne oluşturmak istediğinizden bahsedin...",
                        buttonIdle: "Mesaj Gönder",
                        buttonSending: "Gönderiliyor...",
                        successTitle: "Mesaj Alındı",
                        successMessage: "İletişime geçtiğiniz için teşekkürler! 24-48 saat içinde size dönüş yapacağım.",
                        errorText: "Bir şeyler ters gitti. Lütfen bağlantınızı kontrol edin ve tekrar deneyin."
                    }}
                />
            </div>
        </div>
    </section>
</Layout>
