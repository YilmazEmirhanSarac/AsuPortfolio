---
import Layout from '../../layouts/Layout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { featuredWorks } from '../../data/tr';
---

<Layout title="Çalışmalar | Asu Pınar Aksu" description="Asu Pınar Aksu'nun ürün ve hizmet tasarımı projelerinden seçilmiş bir koleksiyon.">
    <section class="py-12 md:py-20">
        <p class="text-sm font-medium text-neutral-400 uppercase tracking-widest mb-4">Portfolyo</p>
        <h1 class="text-4xl md:text-6xl font-bold tracking-tight text-neutral-900 leading-[1.1] mb-6">Seçili Çalışmalar</h1>
        <p class="text-lg text-neutral-500 max-w-2xl leading-relaxed mb-20">
            Her proje; minimalizm, derin kullanıcı araştırması ve ölçülebilir etki taahhüdünü temsil eder.
        </p>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-16">
            {featuredWorks.map(project => (
                <ProjectCard 
                    title={project.title} 
                    category={project.category} 
                    imageUrl={project.imageUrl} 
                    link={project.link} 
                />
            ))}
        </div>

        <div class="mt-24 pt-16 border-t border-neutral-100 text-center">
            <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-neutral-900 mb-4">Aklınızda bir proje mi var?</h2>
            <p class="text-neutral-500 mb-8 max-w-md mx-auto">Şu anda yeni projeler kabul ediyorum. Birlikte olağanüstü bir şeyler yaratalım.</p>
            <a href="/tr/contact" class="inline-flex px-8 py-4 bg-neutral-900 text-white font-medium rounded-full hover:bg-neutral-800 transition-all duration-300">
                İletişime Geçin
            </a>
        </div>
    </section>
</Layout>
