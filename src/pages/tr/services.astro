---
import Layout from '../../layouts/Layout.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import { services } from '../../data/tr';
---

<Layout title="Hizmetler | Asu Pınar Aksu" description="Asu Pınar Aksu tarafından sunulan Ürün Keşfi, UI Tasarımı, UX Optimizasyonu ve Mentorluk hizmetleri.">
    <section class="py-12 md:py-20">
        <p class="text-sm font-medium text-neutral-400 uppercase tracking-widest mb-4">Neler Sunuyorum</p>
        <h1 class="text-4xl md:text-6xl font-bold tracking-tight text-neutral-900 leading-[1.1] mb-6">Hizmetler</h1>
        <p class="text-lg text-neutral-500 max-w-2xl leading-relaxed mb-20">
            Girişimler, ajanslar ve ürün ekipleriyle iş birliği yaparak araştırma odaklı, kullanıcı merkezli ve ölçeklenebilir tasarım çalışmaları sunuyorum.
        </p>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {services.map(service => (
                <ServiceCard title={service.title} description={service.description} />
            ))}
        </div>

        <div class="mt-24 pt-16 border-t border-neutral-100 text-center">
            <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-neutral-900 mb-4">Birlikte çalışmak ister misiniz?</h2>
            <p class="text-neutral-500 mb-8 max-w-md mx-auto">Vizyonunuzu hayata geçirmek için nasıl yardımcı olabileceğimi konuşalım.</p>
            <a href="/tr/contact" class="inline-flex px-8 py-4 bg-neutral-900 text-white font-medium rounded-full hover:bg-neutral-800 transition-all duration-300">
                İletişime Geçin
            </a>
        </div>
    </section>
</Layout>
