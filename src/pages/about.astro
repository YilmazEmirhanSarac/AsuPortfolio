---
import Layout from '../layouts/Layout.astro';
import { siteMetadata } from '../data/data';
---

<Layout title="About | Asu Pınar Aksu" description="Learn more about Asu Pınar Aksu — a Product & Service Designer focused on minimalism, user research, and mentorship.">
    <section class="py-12 md:py-20 max-w-3xl">
        <p class="text-sm font-medium text-neutral-400 uppercase tracking-widest mb-4">About</p>
        <h1 class="text-4xl md:text-6xl font-bold tracking-tight text-neutral-900 leading-[1.1] mb-12">
            Designing with<br />intention & empathy.
        </h1>

        <div class="space-y-8 text-lg text-neutral-500 leading-relaxed">
            <p>
                Hi, I'm <strong class="text-neutral-900 font-medium">{siteMetadata.author}</strong>. I'm a Product & Service Designer who believes that the best digital experiences are the ones you barely notice — because they just <em>work</em>.
            </p>
            <p>
                My approach is rooted in deep user research, systems thinking, and an obsessive attention to detail. I partner with teams to uncover real user needs and translate them into clean, scalable, and meaningful design solutions.
            </p>
            <p>
                Beyond client work, I'm passionate about mentoring the next generation of designers. I believe in sharing knowledge openly and helping others grow their craft and confidence.
            </p>
        </div>

        <!-- Values -->
        <div class="mt-24 pt-16 border-t border-neutral-100">
            <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-neutral-900 mb-12">Design Philosophy</h2>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
                <div>
                    <h3 class="text-lg font-semibold text-neutral-900 mb-3 tracking-tight">Less is More</h3>
                    <p class="text-neutral-500 text-sm leading-relaxed">Strip away the unnecessary. Every element must earn its place on the screen.</p>
                </div>
                <div>
                    <h3 class="text-lg font-semibold text-neutral-900 mb-3 tracking-tight">Research First</h3>
                    <p class="text-neutral-500 text-sm leading-relaxed">Beautiful interfaces mean nothing if they don't solve a real problem for real people.</p>
                </div>
                <div>
                    <h3 class="text-lg font-semibold text-neutral-900 mb-3 tracking-tight">Systems Thinking</h3>
                    <p class="text-neutral-500 text-sm leading-relaxed">Great design scales. I build design systems and patterns that grow with the product.</p>
                </div>
            </div>
        </div>

        <!-- CTA -->
        <div class="mt-24 pt-16 border-t border-neutral-100">
            <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-neutral-900 mb-4">Want to work together?</h2>
            <p class="text-neutral-500 mb-8">I'm currently open to new projects and collaborations.</p>
            <a href="/contact" class="inline-flex px-8 py-4 bg-neutral-900 text-white font-medium rounded-full hover:bg-neutral-800 transition-all duration-300">
                Get in Touch
            </a>
        </div>
    </section>
</Layout>
